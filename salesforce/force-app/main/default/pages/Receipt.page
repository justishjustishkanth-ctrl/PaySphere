<apex:page controller="ReceiptController" renderAs="pdf" showHeader="false" sidebar="false" standardStylesheets="false" applyBodyTag="false" applyHtmlTag="false">
<html>
<head>
  <style>
    @page {
      size: A4;
      margin: 20mm;
    }
    body {
      font-family: 'Helvetica', 'Arial', sans-serif;
      color: #334155;
      font-size: 13px;
      line-height: 1.5;
    }
    .header {
      border-bottom: 2px solid #2563eb;
      padding-bottom: 20px;
      margin-bottom: 30px;
    }
    .logo-container {
      float: left;
    }
    .logo-text {
      font-size: 24px;
      font-weight: bold;
      color: #1e293b;
    }
    .receipt-title {
      float: right;
      text-align: right;
    }
    .receipt-title h2 {
      margin: 0;
      color: #2563eb;
      font-size: 20px;
    }
    .receipt-title p {
      margin: 5px 0 0 0;
      color: #64748b;
      font-size: 11px;
    }
    .clear {
      clear: both;
    }
    .billing-info {
      margin-bottom: 30px;
    }
    .billing-col {
      width: 48%;
      float: left;
    }
    .billing-col-right {
      width: 48%;
      float: right;
    }
    .section-title {
      font-size: 11px;
      font-weight: bold;
      text-transform: uppercase;
      color: #64748b;
      border-bottom: 1px solid #e2e8f0;
      padding-bottom: 5px;
      margin-bottom: 10px;
    }
    .table-details {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 30px;
    }
    .table-details th {
      background-color: #f8fafc;
      border-bottom: 1px solid #cbd5e1;
      padding: 10px;
      font-size: 11px;
      text-transform: uppercase;
      color: #475569;
      text-align: left;
    }
    .table-details td {
      border-bottom: 1px solid #f1f5f9;
      padding: 12px 10px;
    }
    .summary-section {
      float: right;
      width: 45%;
      margin-top: 10px;
    }
    .summary-row {
      padding: 6px 0;
      border-bottom: 1px solid #f1f5f9;
    }
    .summary-row-total {
      padding: 10px 0;
      border-bottom: 2px double #2563eb;
      font-size: 15px;
      font-weight: bold;
      color: #1e293b;
    }
    .summary-label {
      float: left;
      color: #64748b;
    }
    .summary-value {
      float: right;
      font-weight: bold;
      text-align: right;
    }
    .footer {
      position: fixed;
      bottom: 0;
      width: 100%;
      text-align: center;
      border-top: 1px solid #e2e8f0;
      padding-top: 15px;
      font-size: 10px;
      color: #94a3b8;
    }
  </style>
</head>
<body>

  <div class="header">
    <div class="logo-container">
      <div class="logo-text">PaySphere</div>
      <div style="font-size: 10px; color: #64748b; margin-top: 2px;">ENTERPRISE CROSS-BORDER SETTLEMENTS</div>
    </div>
    <div class="receipt-title">
      <h2>PAYMENT RECEIPT</h2>
      <p>Transaction ID: {!transactionRecord.Name}</p>
    </div>
    <div class="clear"></div>
  </div>

  <div class="billing-info">
    <div class="billing-col">
      <div class="section-title">Customer Details</div>
      <strong>{!customerName}</strong><br/>
      Email: {!transactionRecord.Customer__r.Email__c}<br/>
      Client Account ID: {!transactionRecord.Customer__c}
    </div>
    <div class="billing-col-right">
      <div class="section-title">Settlement Destination</div>
      <strong>{!beneficiaryName}</strong><br/>
      Exchange Conversion: Yes<br/>
      Date/Time: <apex:outputText value="{0,date,yyyy-MM-dd HH:mm:ss}">
        <apex:param value="{!transactionRecord.Timestamp__c}"/>
      </apex:outputText>
    </div>
    <div class="clear"></div>
  </div>

  <div class="section-title" style="margin-top: 15px;">Transaction Details</div>
  <table class="table-details">
    <thead>
      <tr>
        <th>Description</th>
        <th style="text-align: right;">Rate</th>
        <th style="text-align: right;">Source Amount</th>
        <th style="text-align: right;">Total settled</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>
          <strong>Cross-Border Settlement Remittance</strong><br/>
          <span style="font-size: 11px; color: #64748b;">Funds transferred electronically to destination beneficiary bank account.</span>
        </td>
        <td style="text-align: right; font-family: monospace;">
          1 {!transactionRecord.Currency__c} = {!transactionRecord.Transfer_Request__r.Exchange_Rate__c} {!transactionRecord.Transfer_Request__r.Destination_Currency__c}
        </td>
        <td style="text-align: right; font-family: monospace;">
          {!transactionRecord.Currency__c}&nbsp;
          <apex:outputText value="{0, number, ##,##,##0.00}">
            <apex:param value="{!transactionRecord.Amount__c}"/>
          </apex:outputText>
        </td>
        <td style="text-align: right; font-family: monospace; font-weight: bold; color: #10b981;">
          {!transactionRecord.Transfer_Request__r.Destination_Currency__c}&nbsp;
          <apex:outputText value="{0, number, ##,##,##0.0000}">
            <apex:param value="{!transactionRecord.Transfer_Request__r.Receiver_Amount__c}"/>
          </apex:outputText>
        </td>
      </tr>
    </tbody>
  </table>

  <div>
    <div class="summary-section">
      <div class="summary-row">
        <div class="summary-label">Subtotal</div>
        <div class="summary-value">
          {!transactionRecord.Currency__c}&nbsp;
          <apex:outputText value="{0, number, ##,##,##0.00}">
            <apex:param value="{!transactionRecord.Amount__c}"/>
          </apex:outputText>
        </div>
        <div class="clear"></div>
      </div>
      <div class="summary-row">
        <div class="summary-label">Compliance Service Fee</div>
        <div class="summary-value">Included</div>
        <div class="clear"></div>
      </div>
      <div class="summary-row-total">
        <div class="summary-label">Settlement Amount</div>
        <div class="summary-value">
          {!transactionRecord.Currency__c}&nbsp;
          <apex:outputText value="{0, number, ##,##,##0.00}">
            <apex:param value="{!transactionRecord.Amount__c}"/>
          </apex:outputText>
        </div>
        <div class="clear"></div>
      </div>
    </div>
    <div class="clear"></div>
  </div>

  <div style="margin-top: 50px; background-color: #f8fafc; border: 1px solid #cbd5e1; padding: 15px; border-radius: 6px;">
    <div style="font-size: 11px; font-weight: bold; text-transform: uppercase; color: #475569; margin-bottom: 5px;">Compliance Stamp &amp; Disclaimers</div>
    <p style="font-size: 10px; color: #64748b; margin: 0;">
      This transaction receipt is generated automatically upon successful validation of the payment signature from the Razorpay checkout gateway. Funds represent a mock settled transfer in compliance with local testing guidelines. Real borderless settlement occurs pending standard anti-money laundering (AML) and KYC checks.
    </p>
  </div>

  <div class="footer">
    PaySphere Enterprise Payments System · Generated on &nbsp;
    <apex:outputText value="{0,date,yyyy-MM-dd HH:mm:ss}">
      <apex:param value="{!NOW()}"/>
    </apex:outputText>
  </div>

</body>
</html>
</apex:page>
