<apex:page controller="AdminController" showHeader="false" sidebar="false" standardStylesheets="false" docType="html-5.0" title="PaySphere – Admin Dashboard">
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>PaySphere – Admin Console</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&amp;display=swap" rel="stylesheet"/>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            brand: '#2563EB',
            bgLight: '#F0F0EE',
            pillBg: '#EDEDED'
          },
          fontFamily: {
            sans: ['Inter', 'sans-serif'],
          }
        }
      }
    }
  </script>
  <style>
    body { background-color: #F0F0EE; }
    .glass-card {
      background: rgba(255, 255, 255, 0.7);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid rgba(255, 255, 255, 0.5);
    }
  </style>
</head>
<body class="font-sans antialiased text-slate-800 min-h-screen">

  <div class="p-8 max-w-7xl mx-auto space-y-8">
    
    <!-- Header -->
    <header class="flex justify-between items-center">
      <div>
        <div class="flex items-center gap-3 mb-2">
          <div class="w-8 h-8 bg-brand rounded-lg flex items-center justify-center">
            <svg width="16" height="16" viewBox="0 0 256 256" fill="none">
              <path fill="#fff" d="M 160 88 L 194 34 L 216 0 L 256 0 L 256 40 L 221.5 93.5 L 200 128 L 256 128 L 256 256 L 96 256 L 96 168 L 64.246 220 L 40 256 L 0 256 L 0 216 L 34 162 L 56 128 L 0 128 L 0 0 L 160 0 Z"/>
            </svg>
          </div>
          <span class="font-bold text-xl text-slate-900 leading-none">PaySphere Portal</span>
        </div>
        <h1 class="text-2xl font-bold text-slate-900">Compliance &amp; Admin Console</h1>
        <p class="text-sm text-slate-500">Review platform signups, verify beneficiaries, audit high-value transactions, and inspect active fraud triggers.</p>
      </div>
      <div>
        <a href="/apex/Home" class="bg-white border border-slate-200 text-slate-600 hover:text-slate-900 font-semibold px-4 py-2 rounded-xl text-xs transition-all">
          ← Public Home
        </a>
      </div>
    </header>

    <apex:form id="adminForm">
      <!-- Alerts -->
      <apex:outputPanel id="messagePanel" layout="block">
        <apex:outputPanel rendered="{!NOT(ISBLANK(errorMessage))}">
          <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-xl text-red-600 flex items-center gap-3">
            <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
            <span class="font-semibold">{!errorMessage}</span>
          </div>
        </apex:outputPanel>

        <apex:outputPanel rendered="{!NOT(ISBLANK(successMessage))}">
          <div class="mb-6 p-4 bg-green-50 border border-green-200 rounded-xl text-green-700 flex items-center gap-3">
            <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            <span class="font-semibold">{!successMessage}</span>
          </div>
        </apex:outputPanel>
      </apex:outputPanel>

      <!-- KPI Metrics -->
      <section class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Card 1 -->
        <div class="glass-card rounded-2xl p-6 shadow-sm">
          <div class="text-xs font-semibold text-slate-500 tracking-wider uppercase mb-2">Total Registered Clients</div>
          <div class="text-3xl font-bold text-slate-900">{!totalUsers}</div>
          <div class="text-[10px] text-slate-400 mt-2 font-medium">Customer database profiles</div>
        </div>

        <!-- Card 2 -->
        <div class="glass-card rounded-2xl p-6 shadow-sm">
          <div class="text-xs font-semibold text-slate-500 tracking-wider uppercase mb-2">Cumulative Processing Volume</div>
          <div class="text-3xl font-bold text-slate-900">
            <apex:outputText value="₹{0, number, ##,##,##0.00}">
              <apex:param value="{!totalRevenue}"/>
            </apex:outputText>
          </div>
          <div class="text-[10px] text-green-600 mt-2 font-medium">Settled international collections</div>
        </div>

        <!-- Card 3 -->
        <div class="glass-card rounded-2xl p-6 shadow-sm">
          <div class="text-xs font-semibold text-slate-500 tracking-wider uppercase mb-2">Total Settled Transactions</div>
          <div class="text-3xl font-bold text-slate-900">{!totalTransactions}</div>
          <div class="text-[10px] text-slate-400 mt-2 font-medium">Razorpay checkout validations</div>
        </div>
      </section>

      <!-- Grid layout for approvals -->
      <div class="grid grid-cols-1 gap-8">
        
        <!-- 1. Pending KYC Requests -->
        <div class="glass-card rounded-2xl p-6 shadow-sm">
          <h3 class="font-bold text-slate-900 text-base mb-1">Awaiting KYC Approval ({!pendingKYC.size})</h3>
          <p class="text-xs text-slate-500 mb-6">Review legal documents for client registrations</p>

          <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse text-xs">
              <thead>
                <tr class="border-b border-slate-200/60 text-slate-400 font-semibold uppercase tracking-wider">
                  <th class="pb-3">Client Name</th>
                  <th class="pb-3">PAN</th>
                  <th class="pb-3">Aadhaar</th>
                  <th class="pb-3">Passport</th>
                  <th class="pb-3">Rejection comments</th>
                  <th class="pb-3 text-right">Actions</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100/60">
                <apex:repeat value="{!pendingKYC}" var="kyc">
                  <tr>
                    <td class="py-3.5 font-bold text-slate-900">{!kyc.Customer__r.First_Name__c} {!kyc.Customer__r.Last_Name__c}</td>
                    <td class="py-3.5 font-mono">{!kyc.PAN__c}</td>
                    <td class="py-3.5 font-mono">{!kyc.Aadhaar__c}</td>
                    <td class="py-3.5 font-mono">{!kyc.Passport__c}</td>
                    <td class="py-3.5">
                      <apex:inputText value="{!adminComments}" styleClass="ps-input-table" html-placeholder="Reason if rejecting..."/>
                    </td>
                    <td class="py-3.5 text-right space-x-2">
                      <apex:commandButton value="Approve" action="{!approveKYC}" styleClass="bg-green-600 hover:bg-green-700 text-white font-semibold px-3 py-1.5 rounded-lg transition-all cursor-pointer" rerender="adminForm">
                        <apex:param name="recId" value="{!kyc.Id}" assignTo="{!recordId}"/>
                      </apex:commandButton>
                      <apex:commandButton value="Reject" action="{!rejectKYC}" styleClass="bg-red-50 hover:bg-red-600 hover:text-white border border-red-200 text-red-600 font-semibold px-3 py-1.5 rounded-lg transition-all cursor-pointer" rerender="adminForm">
                        <apex:param name="recId" value="{!kyc.Id}" assignTo="{!recordId}"/>
                      </apex:commandButton>
                    </td>
                  </tr>
                </apex:repeat>
                <apex:outputPanel rendered="{!pendingKYC.size == 0}">
                  <tr>
                    <td colspan="6" class="py-6 text-center text-slate-400">No pending KYC submissions.</td>
                  </tr>
                </apex:outputPanel>
              </tbody>
            </table>
          </div>
        </div>

        <!-- 2. Pending Beneficiary Requests -->
        <div class="glass-card rounded-2xl p-6 shadow-sm">
          <h3 class="font-bold text-slate-900 text-base mb-1">Awaiting Beneficiary Clearance ({!pendingBeneficiaries.size})</h3>
          <p class="text-xs text-slate-500 mb-6">Review settlement banks configured by clients</p>

          <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse text-xs">
              <thead>
                <tr class="border-b border-slate-200/60 text-slate-400 font-semibold uppercase tracking-wider">
                  <th class="pb-3">Client</th>
                  <th class="pb-3">Beneficiary</th>
                  <th class="pb-3">Bank Details</th>
                  <th class="pb-3">Country</th>
                  <th class="pb-3 text-right">Actions</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100/60">
                <apex:repeat value="{!pendingBeneficiaries}" var="ben">
                  <tr>
                    <td class="py-3.5 font-semibold text-slate-900">{!ben.Customer__r.First_Name__c} {!ben.Customer__r.Last_Name__c}</td>
                    <td class="py-3.5 font-bold text-slate-950">{!ben.Name}</td>
                    <td class="py-3.5">
                      <div class="font-medium text-slate-800">{!ben.Bank_Name__c}</div>
                      <div class="text-[10px] text-slate-400 font-mono">A/C: {!ben.Account_Number__c}</div>
                    </td>
                    <td class="py-3.5 font-medium">{!ben.Country__c}</td>
                    <td class="py-3.5 text-right space-x-2">
                      <apex:commandButton value="Approve" action="{!approveBeneficiary}" styleClass="bg-green-600 hover:bg-green-700 text-white font-semibold px-3 py-1.5 rounded-lg transition-all cursor-pointer" rerender="adminForm">
                        <apex:param name="recId" value="{!ben.Id}" assignTo="{!recordId}"/>
                      </apex:commandButton>
                      <apex:commandButton value="Reject" action="{!rejectBeneficiary}" styleClass="bg-red-50 hover:bg-red-600 hover:text-white border border-red-200 text-red-600 font-semibold px-3 py-1.5 rounded-lg transition-all cursor-pointer" rerender="adminForm">
                        <apex:param name="recId" value="{!ben.Id}" assignTo="{!recordId}"/>
                      </apex:commandButton>
                    </td>
                  </tr>
                </apex:repeat>
                <apex:outputPanel rendered="{!pendingBeneficiaries.size == 0}">
                  <tr>
                    <td colspan="5" class="py-6 text-center text-slate-400">No pending beneficiary verifications.</td>
                  </tr>
                </apex:outputPanel>
              </tbody>
            </table>
          </div>
        </div>

        <!-- 3. Pending Transfer Approvals (> ₹100,000) -->
        <div class="glass-card rounded-2xl p-6 shadow-sm">
          <h3 class="font-bold text-slate-900 text-base mb-1">Awaiting High-Value Transfer Clearances ({!pendingApprovals.size})</h3>
          <p class="text-xs text-slate-500 mb-6">Remittances exceeding ₹100,000 requiring manually authorized clearance</p>

          <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse text-xs">
              <thead>
                <tr class="border-b border-slate-200/60 text-slate-400 font-semibold uppercase tracking-wider">
                  <th class="pb-3">Client</th>
                  <th class="pb-3">Amount</th>
                  <th class="pb-3">Route</th>
                  <th class="pb-3">Compliance Comments</th>
                  <th class="pb-3 text-right">Actions</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100/60">
                <apex:repeat value="{!pendingApprovals}" var="app">
                  <tr>
                    <td class="py-3.5 font-semibold text-slate-900">{!app.Transfer_Request__r.Customer__r.First_Name__c} {!app.Transfer_Request__r.Customer__r.Last_Name__c}</td>
                    <td class="py-3.5 font-bold text-slate-950">
                      <apex:outputText value="{0, number, ##,##,##0.00}">
                        <apex:param value="{!app.Transfer_Request__r.Amount__c}"/>
                      </apex:outputText>
                    </td>
                    <td class="py-3.5"><span class="px-2 py-0.5 bg-pillBg text-slate-700 rounded font-mono text-[10px]">{!app.Transfer_Request__r.Source_Currency__c} → {!app.Transfer_Request__r.Destination_Currency__c}</span></td>
                    <td class="py-3.5">
                      <apex:inputText value="{!adminComments}" styleClass="ps-input-table" html-placeholder="Clearance audit notes..."/>
                    </td>
                    <td class="py-3.5 text-right space-x-2">
                      <apex:commandButton value="Clear & Approve" action="{!approveTransfer}" styleClass="bg-green-600 hover:bg-green-700 text-white font-semibold px-3 py-1.5 rounded-lg transition-all cursor-pointer" rerender="adminForm">
                        <apex:param name="recId" value="{!app.Id}" assignTo="{!recordId}"/>
                      </apex:commandButton>
                      <apex:commandButton value="Block & Decline" action="{!rejectTransfer}" styleClass="bg-red-50 hover:bg-red-600 hover:text-white border border-red-200 text-red-600 font-semibold px-3 py-1.5 rounded-lg transition-all cursor-pointer" rerender="adminForm">
                        <apex:param name="recId" value="{!app.Id}" assignTo="{!recordId}"/>
                      </apex:commandButton>
                    </td>
                  </tr>
                </apex:repeat>
                <apex:outputPanel rendered="{!pendingApprovals.size == 0}">
                  <tr>
                    <td colspan="5" class="py-6 text-center text-slate-400">No high value transfers held for compliance clearance.</td>
                  </tr>
                </apex:outputPanel>
              </tbody>
            </table>
          </div>
        </div>

        <!-- 4. Active Fraud Logs -->
        <div class="glass-card rounded-2xl p-6 shadow-sm">
          <h3 class="font-bold text-slate-900 text-base mb-1">Platform Security Audits &amp; Fraud Logs</h3>
          <p class="text-xs text-slate-500 mb-6">Real-time alerts triggered by suspicious platform activities</p>

          <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse text-xs">
              <thead>
                <tr class="border-b border-slate-200/60 text-slate-400 font-semibold uppercase tracking-wider">
                  <th class="pb-3">Client</th>
                  <th class="pb-3">Flag Trigger</th>
                  <th class="pb-3">Detailed Audit Trail</th>
                  <th class="pb-3 text-right">Timestamp</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100/60">
                <apex:repeat value="{!activeFraudLogs}" var="fraud">
                  <tr>
                    <td class="py-3.5 font-semibold text-slate-900">{!fraud.Customer__r.First_Name__c} {!fraud.Customer__r.Last_Name__c}</td>
                    <td class="py-3.5">
                      <span class="px-2 py-0.5 bg-red-50 border border-red-200 text-red-700 font-bold rounded text-[10px] uppercase tracking-wide">{!fraud.Flag_Reason__c}</span>
                    </td>
                    <td class="py-3.5 text-slate-600 max-w-[320px] truncate" title="{!fraud.Details__c}">{!fraud.Details__c}</td>
                    <td class="py-3.5 text-right text-slate-400 font-mono">
                      <apex:outputText value="{0,date,yyyy-MM-dd HH:mm:ss}">
                        <apex:param value="{!fraud.Timestamp__c}"/>
                      </apex:outputText>
                    </td>
                  </tr>
                </apex:repeat>
                <apex:outputPanel rendered="{!activeFraudLogs.size == 0}">
                  <tr>
                    <td colspan="4" class="py-6 text-center text-slate-400">All systems green. No fraud logs recorded.</td>
                  </tr>
                </apex:outputPanel>
              </tbody>
            </table>
          </div>
        </div>

      </div>
    </apex:form>
  </div>

  <style>
    .ps-input-table {
      width: 100% !important; padding: 0.4rem 0.6rem !important;
      background: #fff !important;
      border: 1px solid rgba(0, 0, 0, 0.12) !important;
      border-radius: 8px !important; color: #1e293b !important; font-size: 11px !important;
      outline: none !important; display: block !important;
      font-family: 'Inter', sans-serif !important;
    }
  </style>

</body>
</html>
</apex:page>
