<apex:page controller="DashboardController" action="{!checkSession}" showHeader="false" sidebar="false" standardStylesheets="false" docType="html-5.0" title="PaySphere – Dashboard">
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>PaySphere – Dashboard</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&amp;display=swap" rel="stylesheet"/>
  <!-- Tailwind CSS CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            brand: '#2563EB',
            bgLight: '#F0F0EE',
            pillBg: '#EDEDED'
          },
          fontFamily: {
            sans: ['Inter', 'sans-serif'],
          }
        }
      }
    }
  </script>
  <style>
    body { background-color: #F0F0EE; }
    .glass-card {
      background: rgba(255, 255, 255, 0.7);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid rgba(255, 255, 255, 0.5);
    }
    .custom-scroll::-webkit-scrollbar {
      width: 6px;
    }
    .custom-scroll::-webkit-scrollbar-track {
      background: transparent;
    }
    .custom-scroll::-webkit-scrollbar-thumb {
      background: rgba(0,0,0,0.1);
      border-radius: 3px;
    }
  </style>
</head>
<body class="font-sans antialiased text-slate-800 min-h-screen flex">

  <!-- Sidebar -->
  <aside class="w-64 bg-slate-900 text-white flex flex-col justify-between p-6 shrink-0">
    <div>
      <!-- Logo -->
      <div class="flex items-center gap-3 mb-8">
        <div class="w-9 h-9 bg-brand rounded-lg flex items-center justify-center">
          <svg width="18" height="18" viewBox="0 0 256 256" fill="none">
            <path fill="#fff" d="M 160 88 L 194 34 L 216 0 L 256 0 L 256 40 L 221.5 93.5 L 200 128 L 256 128 L 256 256 L 96 256 L 96 168 L 64.246 220 L 40 256 L 0 256 L 0 216 L 34 162 L 56 128 L 0 128 L 0 0 L 160 0 Z"/>
          </svg>
        </div>
        <div>
          <div class="font-bold text-lg leading-tight tracking-tight">PaySphere</div>
          <div class="text-[10px] text-slate-400 font-medium tracking-wider uppercase">Enterprise</div>
        </div>
      </div>

      <!-- Navigation -->
      <nav class="space-y-1">
        <a href="/apex/Dashboard" class="flex items-center gap-3 px-4 py-3 bg-brand text-white font-medium rounded-xl transition-all">
          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <rect x="3" y="3" width="7" height="7" rx="1"/>
            <rect x="14" y="3" width="7" height="7" rx="1"/>
            <rect x="14" y="14" width="7" height="7" rx="1"/>
            <rect x="3" y="14" width="7" height="7" rx="1"/>
          </svg>
          Dashboard
        </a>
        <a href="/apex/Beneficiary" class="flex items-center gap-3 px-4 py-3 text-slate-300 hover:bg-slate-800 hover:text-white rounded-xl transition-all">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
            <circle cx="9" cy="7" r="4"/>
            <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
          </svg>
          Beneficiaries
        </a>
        <a href="/apex/Transfer" class="flex items-center gap-3 px-4 py-3 text-slate-300 hover:bg-slate-800 hover:text-white rounded-xl transition-all">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path d="M16 3h5v5"/>
            <path d="M4 20L21 3"/>
            <path d="M21 16v5h-5"/>
            <path d="M15 15l6 6"/>
            <path d="M4 4l6 6"/>
          </svg>
          Make Transfer
        </a>
        <a href="/apex/History" class="flex items-center gap-3 px-4 py-3 text-slate-300 hover:bg-slate-800 hover:text-white rounded-xl transition-all">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path d="M12 8v4l3 3"/>
            <circle cx="12" cy="12" r="9"/>
          </svg>
          Transfer History
        </a>
        <a href="/apex/KYC" class="flex items-center gap-3 px-4 py-3 text-slate-300 hover:bg-slate-800 hover:text-white rounded-xl transition-all">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="16" y1="13" x2="8" y2="13"/>
            <line x1="16" y1="17" x2="8" y2="17"/>
            <polyline points="10 9 9 9 8 9"/>
          </svg>
          KYC Verification
        </a>
        <a href="/apex/Notifications" class="flex items-center gap-3 px-4 py-3 text-slate-300 hover:bg-slate-800 hover:text-white rounded-xl transition-all">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
            <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
          </svg>
          Notifications
        </a>
      </nav>
    </div>

    <!-- User Section -->
    <div class="border-t border-slate-800 pt-6">
      <apex:outputPanel rendered="{!currentCustomer != null}">
        <div class="mb-4">
          <div class="text-sm font-semibold truncate">{!currentCustomer.First_Name__c} {!currentCustomer.Last_Name__c}</div>
          <div class="text-xs text-slate-400 truncate">{!currentCustomer.Email__c}</div>
        </div>
      </apex:outputPanel>
      <button onclick="logout()" class="w-full flex items-center justify-center gap-2 px-4 py-2 bg-red-600/20 hover:bg-red-600 text-red-400 hover:text-white text-xs font-semibold rounded-lg transition-all">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
          <polyline points="16 17 21 12 16 7"/>
          <line x1="21" y1="12" x2="9" y2="12"/>
        </svg>
        Sign Out
      </button>
    </div>
  </aside>

  <!-- Main Content -->
  <main class="flex-1 p-8 overflow-y-auto">
    <!-- Header -->
    <header class="flex justify-between items-center mb-8">
      <div>
        <h1 class="text-2xl font-bold text-slate-900">Welcome back, {!currentCustomer.First_Name__c}</h1>
        <p class="text-sm text-slate-500">Monitor your enterprise cross-border collections and settlements.</p>
      </div>
      <div class="flex items-center gap-4">
        <a href="/apex/Notifications" class="w-10 h-10 bg-white hover:bg-slate-50 border border-slate-200 rounded-xl flex items-center justify-center text-slate-600 transition-all relative">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
            <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
          </svg>
          <apex:outputPanel rendered="{!recentNotifications.size > 0}">
            <span class="absolute -top-1 -right-1 w-3.5 h-3.5 bg-red-500 border-2 border-white rounded-full"></span>
          </apex:outputPanel>
        </a>
      </div>
    </header>

    <!-- Error/Session Notice -->
    <apex:outputPanel rendered="{!NOT(ISBLANK(errorMessage))}">
      <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-xl text-red-600 flex items-center gap-3">
        <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
        </svg>
        <div>
          <span class="font-semibold">{!errorMessage}</span>
          <a href="/apex/Login" class="underline ml-2">Click here to Sign In</a>
        </div>
      </div>
    </apex:outputPanel>

    <!-- Content only if logged in -->
    <apex:outputPanel rendered="{!currentCustomer != null}">
      <!-- Metrics Grid -->
      <section class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
        <!-- Metric 1 -->
        <div class="glass-card rounded-2xl p-6 shadow-sm">
          <div class="flex justify-between items-start mb-4">
            <div class="text-xs font-semibold text-slate-500 tracking-wider uppercase">Total Payments Volume</div>
            <div class="p-2 bg-blue-50 text-brand rounded-lg">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path d="M12 1v22M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
              </svg>
            </div>
          </div>
          <div class="text-2xl font-bold text-slate-900">
            <apex:outputText value="₹{0, number, ##,##,##0.00}">
              <apex:param value="{!totalPayments}"/>
            </apex:outputText>
          </div>
          <div class="text-[11px] text-slate-500 mt-2">Cumulative settled transactions</div>
        </div>

        <!-- Metric 2 -->
        <div class="glass-card rounded-2xl p-6 shadow-sm">
          <div class="flex justify-between items-start mb-4">
            <div class="text-xs font-semibold text-slate-500 tracking-wider uppercase">Success Transactions</div>
            <div class="p-2 bg-green-50 text-green-600 rounded-lg">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
            </div>
          </div>
          <div class="text-2xl font-bold text-slate-900">{!successfulPayments}</div>
          <div class="text-[11px] text-green-600 mt-2 font-medium">Completed and settled</div>
        </div>

        <!-- Metric 3 -->
        <div class="glass-card rounded-2xl p-6 shadow-sm">
          <div class="flex justify-between items-start mb-4">
            <div class="text-xs font-semibold text-slate-500 tracking-wider uppercase">Failed Transactions</div>
            <div class="p-2 bg-red-50 text-red-600 rounded-lg">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <line x1="18" y1="6" x2="6" y2="18"/>
                <line x1="6" y1="6" x2="18" y2="18"/>
              </svg>
            </div>
          </div>
          <div class="text-2xl font-bold text-slate-900">{!failedPayments}</div>
          <div class="text-[11px] text-red-500 mt-2 font-medium">Errors or insufficient funds</div>
        </div>

        <!-- Metric 4 -->
        <div class="glass-card rounded-2xl p-6 shadow-sm">
          <div class="flex justify-between items-start mb-4">
            <div class="text-xs font-semibold text-slate-500 tracking-wider uppercase">Pending Payments</div>
            <div class="p-2 bg-yellow-50 text-yellow-600 rounded-lg">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
            </div>
          </div>
          <div class="text-2xl font-bold text-slate-900">{!pendingRequests}</div>
          <div class="text-[11px] text-yellow-600 mt-2 font-medium">Awaiting Razorpay confirmation</div>
        </div>
      </section>

      <!-- Grid: Left side Transactions, Right side Rates + Notifications -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        
        <!-- Left 2 columns: Recent Transactions -->
        <div class="lg:col-span-2 space-y-8">
          <div class="glass-card rounded-2xl p-6 shadow-sm">
            <div class="flex justify-between items-center mb-6">
              <div>
                <h3 class="font-bold text-slate-900 text-base">Recent Transactions</h3>
                <p class="text-xs text-slate-500">Your latest 5 financial activities</p>
              </div>
              <a href="/apex/History" class="text-xs font-semibold text-brand hover:underline">View all</a>
            </div>

            <div class="overflow-x-auto">
              <table class="w-full text-left border-collapse">
                <thead>
                  <tr class="border-b border-slate-200/60 text-slate-400 text-[11px] font-semibold tracking-wider uppercase">
                    <th class="pb-3">Transaction ID</th>
                    <th class="pb-3">Amount</th>
                    <th class="pb-3">Currency</th>
                    <th class="pb-3">Status</th>
                    <th class="pb-3">Date</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-slate-100/60 text-xs">
                  <apex:repeat value="{!recentTransactions}" var="tx">
                    <tr>
                      <td class="py-3.5 font-medium text-slate-900">{!tx.Name}</td>
                      <td class="py-3.5 font-semibold text-slate-950">
                        <apex:outputText value="{0, number, ##,##,##0.00}">
                          <apex:param value="{!tx.Amount__c}"/>
                        </apex:outputText>
                      </td>
                      <td class="py-3.5"><span class="px-2 py-0.5 bg-pillBg text-slate-700 rounded-md font-mono text-[10px]">{!tx.Currency__c}</span></td>
                      <td class="py-3.5">
                        <apex:outputPanel rendered="{!tx.Status__c == 'SUCCESS' || tx.Status__c == 'COMPLETED'}">
                          <span class="px-2.5 py-0.5 bg-green-50 text-green-700 border border-green-200/50 rounded-full font-semibold">Success</span>
                        </apex:outputPanel>
                        <apex:outputPanel rendered="{!tx.Status__c == 'FAILED'}">
                          <span class="px-2.5 py-0.5 bg-red-50 text-red-700 border border-red-200/50 rounded-full font-semibold">Failed</span>
                        </apex:outputPanel>
                        <apex:outputPanel rendered="{!tx.Status__c != 'SUCCESS' && tx.Status__c != 'COMPLETED' && tx.Status__c != 'FAILED'}">
                          <span class="px-2.5 py-0.5 bg-yellow-50 text-yellow-700 border border-yellow-200/50 rounded-full font-semibold">{!tx.Status__c}</span>
                        </apex:outputPanel>
                      </td>
                      <td class="py-3.5 text-slate-500">
                        <apex:outputText value="{0,date,yyyy-MM-dd HH:mm}">
                          <apex:param value="{!tx.Timestamp__c}"/>
                        </apex:outputText>
                      </td>
                    </tr>
                  </apex:repeat>
                  <apex:outputPanel rendered="{!recentTransactions.size == 0}">
                    <tr>
                      <td colspan="5" class="py-8 text-center text-slate-400">No transactions recorded yet. <a href="/apex/Transfer" class="text-brand font-semibold hover:underline">Start a transfer</a>.</td>
                    </tr>
                  </apex:outputPanel>
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <!-- Right 1 column: Exchange Rates & Notifications -->
        <div class="space-y-8">
          <!-- Exchange Rates -->
          <div class="glass-card rounded-2xl p-6 shadow-sm">
            <h3 class="font-bold text-slate-900 text-base mb-1">Exchange Rates</h3>
            <p class="text-xs text-slate-500 mb-6">Real-time benchmark conversions</p>

            <div class="space-y-4">
              <apex:repeat value="{!exchangeRates}" var="rate">
                <div class="flex items-center justify-between p-3 bg-white/50 border border-slate-100 rounded-xl">
                  <div class="flex items-center gap-2">
                    <span class="font-bold text-xs text-slate-800">{!rate.Source_Currency__c}</span>
                    <svg class="w-3.5 h-3.5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                      <polyline points="9 18 15 12 9 6"/>
                    </svg>
                    <span class="font-bold text-xs text-slate-800">{!rate.Destination_Currency__c}</span>
                  </div>
                  <div class="text-right">
                    <div class="font-semibold text-xs text-slate-900 font-mono">
                      <apex:outputText value="{0, number, 0.0000}">
                        <apex:param value="{!rate.Rate__c}"/>
                      </apex:outputText>
                    </div>
                  </div>
                </div>
              </apex:repeat>
              <apex:outputPanel rendered="{!exchangeRates.size == 0}">
                <div class="p-6 text-center text-slate-400 text-xs">No exchange rates loaded.</div>
              </apex:outputPanel>
            </div>
          </div>

          <!-- Recent Notifications -->
          <div class="glass-card rounded-2xl p-6 shadow-sm">
            <div class="flex justify-between items-center mb-6">
              <div>
                <h3 class="font-bold text-slate-900 text-base">Alerts &amp; Notices</h3>
                <p class="text-xs text-slate-500">Security &amp; transfer alerts</p>
              </div>
              <a href="/apex/Notifications" class="text-xs font-semibold text-brand hover:underline">View all</a>
            </div>

            <div class="space-y-4 max-h-[300px] overflow-y-auto custom-scroll pr-1">
              <apex:repeat value="{!recentNotifications}" var="notif">
                <div class="flex gap-3 text-xs">
                  <div class="shrink-0 mt-0.5">
                    <apex:outputPanel rendered="{!notif.Type__c == 'FRAUD' || notif.Type__c == 'ALERT'}">
                      <span class="w-2 h-2 block rounded-full bg-red-500"></span>
                    </apex:outputPanel>
                    <apex:outputPanel rendered="{!notif.Type__c != 'FRAUD' && notif.Type__c != 'ALERT'}">
                      <span class="w-2 h-2 block rounded-full bg-blue-500"></span>
                    </apex:outputPanel>
                  </div>
                  <div>
                    <p class="text-slate-800 leading-normal">{!notif.Message__c}</p>
                    <span class="text-[10px] text-slate-400 mt-1 block">
                      <apex:outputText value="{0,date,yyyy-MM-dd HH:mm}">
                        <apex:param value="{!notif.Timestamp__c}"/>
                      </apex:outputText>
                    </span>
                  </div>
                </div>
              </apex:repeat>
              <apex:outputPanel rendered="{!recentNotifications.size == 0}">
                <div class="p-6 text-center text-slate-400 text-xs">No notifications yet.</div>
              </apex:outputPanel>
            </div>
          </div>
        </div>

      </div>
    </apex:outputPanel>
  </main>

  <script>
    function logout() {
      document.cookie = "paysphere_session=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;";
      window.location.href = '/apex/Login';
    }
  </script>
</body>
</html>
</apex:page>
