<apex:page controller="KYCController" action="{!checkSession}" showHeader="false" sidebar="false" standardStylesheets="false" docType="html-5.0" title="PaySphere – KYC Verification">
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>PaySphere – KYC Verification</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&amp;display=swap" rel="stylesheet"/>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            brand: '#2563EB',
            bgLight: '#F0F0EE',
            pillBg: '#EDEDED'
          },
          fontFamily: {
            sans: ['Inter', 'sans-serif'],
          }
        }
      }
    }
  </script>
  <style>
    body { background-color: #F0F0EE; }
    .glass-card {
      background: rgba(255, 255, 255, 0.7);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid rgba(255, 255, 255, 0.5);
    }
  </style>
</head>
<body class="font-sans antialiased text-slate-800 min-h-screen flex">

  <!-- Sidebar -->
  <aside class="w-64 bg-slate-900 text-white flex flex-col justify-between p-6 shrink-0">
    <div>
      <!-- Logo -->
      <div class="flex items-center gap-3 mb-8">
        <div class="w-9 h-9 bg-brand rounded-lg flex items-center justify-center">
          <svg width="18" height="18" viewBox="0 0 256 256" fill="none">
            <path fill="#fff" d="M 160 88 L 194 34 L 216 0 L 256 0 L 256 40 L 221.5 93.5 L 200 128 L 256 128 L 256 256 L 96 256 L 96 168 L 64.246 220 L 40 256 L 0 256 L 0 216 L 34 162 L 56 128 L 0 128 L 0 0 L 160 0 Z"/>
          </svg>
        </div>
        <div>
          <div class="font-bold text-lg leading-tight tracking-tight">PaySphere</div>
          <div class="text-[10px] text-slate-400 font-medium tracking-wider uppercase">Enterprise</div>
        </div>
      </div>

      <!-- Navigation -->
      <nav class="space-y-1">
        <a href="/apex/Dashboard" class="flex items-center gap-3 px-4 py-3 text-slate-300 hover:bg-slate-800 hover:text-white rounded-xl transition-all">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <rect x="3" y="3" width="7" height="7" rx="1"/>
            <rect x="14" y="3" width="7" height="7" rx="1"/>
            <rect x="14" y="14" width="7" height="7" rx="1"/>
            <rect x="3" y="14" width="7" height="7" rx="1"/>
          </svg>
          Dashboard
        </a>
        <a href="/apex/Beneficiary" class="flex items-center gap-3 px-4 py-3 text-slate-300 hover:bg-slate-800 hover:text-white rounded-xl transition-all">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
            <circle cx="9" cy="7" r="4"/>
            <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
          </svg>
          Beneficiaries
        </a>
        <a href="/apex/Transfer" class="flex items-center gap-3 px-4 py-3 text-slate-300 hover:bg-slate-800 hover:text-white rounded-xl transition-all">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path d="M16 3h5v5"/>
            <path d="M4 20L21 3"/>
            <path d="M21 16v5h-5"/>
            <path d="M15 15l6 6"/>
            <path d="M4 4l6 6"/>
          </svg>
          Make Transfer
        </a>
        <a href="/apex/History" class="flex items-center gap-3 px-4 py-3 text-slate-300 hover:bg-slate-800 hover:text-white rounded-xl transition-all">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path d="M12 8v4l3 3"/>
            <circle cx="12" cy="12" r="9"/>
          </svg>
          Transfer History
        </a>
        <a href="/apex/KYC" class="flex items-center gap-3 px-4 py-3 bg-brand text-white font-medium rounded-xl transition-all">
          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="16" y1="13" x2="8" y2="13"/>
            <line x1="16" y1="17" x2="8" y2="17"/>
            <polyline points="10 9 9 9 8 9"/>
          </svg>
          KYC Verification
        </a>
        <a href="/apex/Notifications" class="flex items-center gap-3 px-4 py-3 text-slate-300 hover:bg-slate-800 hover:text-white rounded-xl transition-all">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
            <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
          </svg>
          Notifications
        </a>
      </nav>
    </div>

    <!-- User Section -->
    <div class="border-t border-slate-800 pt-6">
      <button onclick="logout()" class="w-full flex items-center justify-center gap-2 px-4 py-2 bg-red-600/20 hover:bg-red-600 text-red-400 hover:text-white text-xs font-semibold rounded-lg transition-all">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
          <polyline points="16 17 21 12 16 7"/>
          <line x1="21" y1="12" x2="9" y2="12"/>
        </svg>
        Sign Out
      </button>
    </div>
  </aside>

  <!-- Main Content -->
  <main class="flex-1 p-8 overflow-y-auto">
    <!-- Header -->
    <header class="flex justify-between items-center mb-8">
      <div>
        <h1 class="text-2xl font-bold text-slate-900">KYC Verification</h1>
        <p class="text-sm text-slate-500">Provide legal identification credentials to enable full enterprise transactional settlement limits.</p>
      </div>
    </header>

    <apex:form id="kycForm">
      <!-- Error Feedback -->
      <apex:outputPanel id="messagePanel" layout="block" styleClass="mb-6">
        <apex:outputPanel rendered="{!NOT(ISBLANK(errorMessage))}">
          <div class="p-4 bg-red-50 border border-red-200 rounded-xl text-red-600 flex items-center gap-3">
            <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
            <span class="font-semibold">{!errorMessage}</span>
          </div>
        </apex:outputPanel>
      </apex:outputPanel>

      <div class="max-w-2xl mx-auto space-y-6">
        <!-- Status Banners -->
        <apex:outputPanel rendered="{!status == 'APPROVED'}" layout="block" styleClass="p-5 bg-green-50 border border-green-200 text-green-800 rounded-2xl flex items-start gap-4">
          <div class="p-2 bg-green-100 rounded-xl text-green-700">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
          </div>
          <div>
            <h4 class="font-bold text-sm">KYC Approved &amp; Active</h4>
            <p class="text-xs text-green-600/90 leading-relaxed mt-1">Your identity verification details have been successfully audited. Your cross-border collection limits are fully unlocked.</p>
          </div>
        </apex:outputPanel>

        <apex:outputPanel rendered="{!status == 'PENDING'}" layout="block" styleClass="p-5 bg-yellow-50 border border-yellow-200 text-yellow-800 rounded-2xl flex items-start gap-4">
          <div class="p-2 bg-yellow-100 rounded-xl text-yellow-700">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
            </svg>
          </div>
          <div>
            <h4 class="font-bold text-sm">Verification Under Review</h4>
            <p class="text-xs text-yellow-700/90 leading-relaxed mt-1">Our compliance desk is currently reviewing your uploaded documents. Standard transaction settlement is held to a limit of ₹10,000 in this phase.</p>
          </div>
        </apex:outputPanel>

        <apex:outputPanel rendered="{!status == 'REJECTED'}" layout="block" styleClass="p-5 bg-red-50 border border-red-200 text-red-800 rounded-2xl flex items-start gap-4">
          <div class="p-2 bg-red-100 rounded-xl text-red-700">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
          </div>
          <div>
            <h4 class="font-bold text-sm">Verification Rejected</h4>
            <p class="text-xs text-red-600/90 leading-relaxed mt-1">Your submitted document credentials did not pass verification. Please inspect details, ensure images are readable, and resubmit immediately.</p>
          </div>
        </apex:outputPanel>

        <apex:outputPanel rendered="{!OR(status == 'Not Submitted', status == '')}" layout="block" styleClass="p-5 bg-blue-50 border border-blue-200 text-blue-800 rounded-2xl flex items-start gap-4">
          <div class="p-2 bg-blue-100 rounded-xl text-blue-700">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
          </div>
          <div>
            <h4 class="font-bold text-sm">Identity Verification Required</h4>
            <p class="text-xs text-blue-600/90 leading-relaxed mt-1">Under regulatory compliance mandates, you must submit primary identities (PAN &amp; Aadhaar) before executing international remittances.</p>
          </div>
        </apex:outputPanel>

        <!-- KYC Details Card -->
        <div class="glass-card rounded-2xl p-8 shadow-sm">
          <h3 class="font-bold text-slate-900 text-base mb-6 border-b border-slate-200/60 pb-4">Document Details</h3>

          <div class="space-y-4">
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-xs font-semibold text-slate-500 mb-1 uppercase tracking-wider">PAN Card Number *</label>
                <apex:inputText value="{!pan}" styleClass="ps-input" html-placeholder="ABCDE1234F" disabled="{!OR(status == 'PENDING', status == 'APPROVED')}"/>
              </div>
              <div>
                <label class="block text-xs font-semibold text-slate-500 mb-1 uppercase tracking-wider">Aadhaar Card Number *</label>
                <apex:inputText value="{!aadhaar}" styleClass="ps-input" html-placeholder="#### #### ####" disabled="{!OR(status == 'PENDING', status == 'APPROVED')}"/>
              </div>
            </div>

            <div>
              <label class="block text-xs font-semibold text-slate-500 mb-1 uppercase tracking-wider">Passport Number (Optional)</label>
              <apex:inputText value="{!passport}" styleClass="ps-input" html-placeholder="A1234567" disabled="{!OR(status == 'PENDING', status == 'APPROVED')}"/>
            </div>

            <div>
              <label class="block text-xs font-semibold text-slate-500 mb-1 uppercase tracking-wider">Registered Address *</label>
              <apex:inputTextarea value="{!address}" styleClass="ps-input-area" rows="3" html-placeholder="Corporate headquarter or residential billing address" disabled="{!OR(status == 'PENDING', status == 'APPROVED')}"/>
            </div>

            <div>
              <label class="block text-xs font-semibold text-slate-500 mb-1 uppercase tracking-wider">Document Metadata URL (PDF/JPEG Link)</label>
              <apex:inputText value="{!documentUrl}" styleClass="ps-input" html-placeholder="https://company.com/kyc/pan_scan.pdf" disabled="{!OR(status == 'PENDING', status == 'APPROVED')}"/>
              <p class="text-[10px] text-slate-400 mt-1">Upload scan of PAN/Aadhaar to cloud storage and paste link here for admin audit checks.</p>
            </div>

            <!-- Submit buttons visible only if eligible -->
            <apex:outputPanel rendered="{!OR(status == 'Not Submitted', status == 'REJECTED', status == '')}" layout="block" styleClass="pt-4 border-t border-slate-100">
              <apex:commandButton value="Submit for Verification" action="{!submitKYC}" styleClass="w-full bg-brand text-white font-bold py-3 rounded-xl hover:bg-blue-700 transition-all cursor-pointer" rerender="kycForm"/>
            </apex:outputPanel>
          </div>
        </div>
      </div>
    </apex:form>
  </main>

  <style>
    .ps-input {
      width: 100% !important; padding: 0.65rem 0.85rem !important;
      background: #fff !important;
      border: 1px solid rgba(0, 0, 0, 0.12) !important;
      border-radius: 10px !important; color: #1e293b !important; font-size: 13px !important;
      outline: none !important; display: block !important;
      font-family: 'Inter', sans-serif !important;
      transition: all 0.2s;
    }
    .ps-input:focus { border-color: #2563eb !important; }
    .ps-input:disabled { background-color: #f1f5f9 !important; color: #64748b !important; cursor: not-allowed !important; }

    .ps-input-area {
      width: 100% !important; padding: 0.65rem 0.85rem !important;
      background: #fff !important;
      border: 1px solid rgba(0, 0, 0, 0.12) !important;
      border-radius: 10px !important; color: #1e293b !important; font-size: 13px !important;
      outline: none !important; display: block !important;
      font-family: 'Inter', sans-serif !important;
      transition: all 0.2s;
      resize: none;
    }
    .ps-input-area:focus { border-color: #2563eb !important; }
    .ps-input-area:disabled { background-color: #f1f5f9 !important; color: #64748b !important; cursor: not-allowed !important; }
  </style>

  <script>
    function logout() {
      document.cookie = "paysphere_session=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;";
      window.location.href = '/apex/Login';
    }
  </script>
</body>
</html>
</apex:page>
