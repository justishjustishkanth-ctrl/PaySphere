<apex:page controller="RazorpayController" showHeader="false" sidebar="false" standardStylesheets="false" docType="html-5.0" title="PaySphere – Secure Checkout">
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>PaySphere – Secure Checkout</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&amp;display=swap" rel="stylesheet"/>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            brand: '#2563EB',
            bgLight: '#F0F0EE',
            pillBg: '#EDEDED'
          },
          fontFamily: {
            sans: ['Inter', 'sans-serif'],
          }
        }
      }
    }
  </script>
  <!-- Razorpay Checkout JS -->
  <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
  <style>
    body { background-color: #F0F0EE; }
    .glass-card {
      background: rgba(255, 255, 255, 0.7);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid rgba(255, 255, 255, 0.5);
    }
  </style>
</head>
<body class="font-sans antialiased text-slate-800 min-h-screen flex items-center justify-center p-4">

  <div class="glass-card rounded-2xl p-8 max-w-md w-full shadow-2xl relative overflow-hidden">
    <!-- Blue Glow Spot -->
    <div class="absolute top-0 right-0 w-32 h-32 bg-brand/10 rounded-full blur-2xl -mr-16 -mt-16"></div>

    <!-- Header / Brand -->
    <div class="flex items-center gap-3 mb-8">
      <div class="w-9 h-9 bg-brand rounded-lg flex items-center justify-center shadow-lg shadow-brand/20">
        <svg width="18" height="18" viewBox="0 0 256 256" fill="none">
          <path fill="#fff" d="M 160 88 L 194 34 L 216 0 L 256 0 L 256 40 L 221.5 93.5 L 200 128 L 256 128 L 256 256 L 96 256 L 96 168 L 64.246 220 L 40 256 L 0 256 L 0 216 L 34 162 L 56 128 L 0 128 L 0 0 L 160 0 Z"/>
        </svg>
      </div>
      <div>
        <div class="font-bold text-lg leading-tight tracking-tight text-slate-900">PaySphere Checkout</div>
        <div class="text-[10px] text-slate-400 font-semibold tracking-wider uppercase">Secure Gateways</div>
      </div>
    </div>

    <!-- Transaction Summary -->
    <div class="bg-slate-900 text-white rounded-xl p-5 mb-6 shadow-inner space-y-3">
      <div class="text-[10px] text-slate-400 font-bold uppercase tracking-wider">Checkout Summary</div>
      
      <div class="flex justify-between items-baseline border-b border-slate-800 pb-2.5">
        <span class="text-xs text-slate-400">Currency</span>
        <span class="font-bold text-sm font-mono">{!currencyCode}</span>
      </div>

      <div class="flex justify-between items-baseline border-b border-slate-800 pb-2.5">
        <span class="text-xs text-slate-400">Net Transfer Amount</span>
        <span class="font-bold text-base font-mono">
          <apex:outputText value="{0, number, ##,##,##0.00}">
            <apex:param value="{!transferRequest.Amount__c}"/>
          </apex:outputText>
        </span>
      </div>

      <div class="flex justify-between items-baseline">
        <span class="text-xs text-slate-400">Order ID</span>
        <span class="font-medium text-xs font-mono truncate max-w-[180px]">{!orderId}</span>
      </div>
    </div>

    <!-- Feedback Alerts -->
    <apex:outputPanel id="messagePanel" layout="block" styleClass="mb-6">
      <apex:outputPanel rendered="{!NOT(ISBLANK(errorMessage))}">
        <div class="p-3 bg-red-50 border border-red-200 rounded-xl text-red-600 text-xs flex items-center gap-2">
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
          </svg>
          <span class="font-medium">{!errorMessage}</span>
        </div>
      </apex:outputPanel>

      <apex:outputPanel rendered="{!NOT(ISBLANK(successMessage))}">
        <div class="p-3 bg-green-50 border border-green-200 rounded-xl text-green-700 text-xs flex items-center gap-2">
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
          <span class="font-medium">{!successMessage}</span>
        </div>
      </apex:outputPanel>
    </apex:outputPanel>

    <!-- Hidden Forms for Razorpay Postbacks -->
    <apex:form id="paymentForm">
      <apex:inputHidden id="paymentId" value="{!paymentId}"/>
      <apex:inputHidden id="signature" value="{!signature}"/>
      
      <apex:actionFunction name="verifyPaymentAction" action="{!verifyPayment}" rerender="messagePanel,processingOverlay"/>
    </apex:form>

    <!-- Interactive Buttons -->
    <div class="space-y-3">
      <!-- Pay via Razorpay -->
      <button onclick="payWithRazorpay()" class="w-full flex items-center justify-center gap-3 bg-brand text-white font-bold py-3.5 px-6 rounded-xl hover:bg-blue-700 active:scale-[0.98] transition-all cursor-pointer shadow-lg shadow-brand/20">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/>
        </svg>
        Pay with Razorpay
      </button>

      <!-- Simulation Fallback for Local Environments -->
      <button onclick="simulateMockSuccess()" class="w-full flex items-center justify-center gap-2 bg-emerald-600 hover:bg-emerald-700 text-white font-semibold py-3 px-6 rounded-xl transition-all cursor-pointer">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/>
        </svg>
        Simulate Success Payout (Mock)
      </button>
      
      <a href="/apex/Dashboard" class="block text-center text-xs text-slate-500 hover:text-slate-800 hover:underline pt-2">Cancel &amp; Return to Dashboard</a>
    </div>

    <!-- Security Badging -->
    <div class="mt-8 border-t border-slate-100 pt-4 flex items-center justify-center gap-4 text-[10px] text-slate-400">
      <span class="flex items-center gap-1.5">
        <svg class="w-3.5 h-3.5 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
        </svg>
        PCI-DSS Compliant
      </span>
      <span>·</span>
      <span>256-bit SSL</span>
    </div>
  </div>

  <!-- Processing Spinner Overlay -->
  <div id="processingOverlay" class="hidden fixed inset-0 bg-slate-900/40 backdrop-blur-sm flex items-center justify-center z-50">
    <div class="bg-white rounded-2xl p-6 shadow-2xl flex flex-col items-center gap-4 max-w-xs text-center">
      <div class="w-12 h-12 border-4 border-brand border-t-transparent rounded-full animate-spin"></div>
      <div class="text-sm font-bold text-slate-900">Verifying Payment</div>
      <div class="text-xs text-slate-400 leading-relaxed">Securing HMAC-SHA256 signature clearance &amp; syncing transaction tables...</div>
    </div>
  </div>

  <script>
    function payWithRazorpay() {
      const orderIdVal = "{!orderId}";
      if (!orderIdVal || orderIdVal === '') {
        alert("Unable to initialize Razorpay checkout. Check controller Order ID initialization.");
        return;
      }

      const options = {
        "key": "{!razorpayKey}",
        "amount": "{!amountInPaise}",
        "currency": "{!currencyCode}",
        "name": "PaySphere",
        "description": "Cross-Border Settlement Payout",
        "order_id": orderIdVal,
        "handler": function (response) {
          showSpinner();
          document.getElementById('{!$Component.paymentForm.paymentId}').value = response.razorpay_payment_id;
          document.getElementById('{!$Component.paymentForm.signature}').value = response.razorpay_signature;
          verifyPaymentAction();
        },
        "prefill": {
          "name": "{!customerName}",
          "email": "{!customerEmail}",
          "contact": "{!customerMobile}"
        },
        "theme": {
          "color": "#2563EB"
        }
      };

      try {
        const rzp1 = new Razorpay(options);
        rzp1.on('payment.failed', function (response){
          alert("Payment failed: " + response.error.description);
        });
        rzp1.open();
      } catch (err) {
        alert("Failed to open Razorpay gateway. Falling back to local simulation mode.");
      }
    }

    function simulateMockSuccess() {
      showSpinner();
      const mockPayId = "pay_mock_" + Math.random().toString(36).substring(2, 12);
      const mockSig = "mock_sig_" + Math.random().toString(36).substring(2, 24);
      
      document.getElementById('{!$Component.paymentForm.paymentId}').value = mockPayId;
      document.getElementById('{!$Component.paymentForm.signature}').value = mockSig;
      verifyPaymentAction();
    }

    function showSpinner() {
      document.getElementById('processingOverlay').classList.remove('hidden');
    }
  </script>

</body>
</html>
</apex:page>
