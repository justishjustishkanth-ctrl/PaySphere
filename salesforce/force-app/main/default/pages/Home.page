<apex:page controller="LoginController" showHeader="false" sidebar="false" standardStylesheets="false" docType="html-5.0" title="PaySphere – Home">
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <meta name="description" content="PaySphere – Secure cross-border payments and transaction tracking for modern enterprises."/>
  <title>PaySphere – Enterprise Payment Platform</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&amp;display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Inter', ui-sans-serif, system-ui, -apple-system, sans-serif; background: #f0f0ee; overflow: hidden; height: 100vh; }

    /* VIDEO BACKGROUND */
    .video-bg { position: fixed; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: 0; }

    /* FOREGROUND */
    .page-wrapper { position: relative; z-index: 10; display: flex; flex-direction: column; min-height: 100vh; }

    /* NAVBAR */
    nav { display: flex; align-items: center; justify-content: center; padding: 1.25rem 2rem; gap: 0.6rem; }
    .nav-logo-pill {
      display: flex; align-items: center; justify-content: center;
      width: 42px; height: 42px; border-radius: 50%; background: #EDEDED; flex-shrink: 0;
    }
    .nav-links-pill {
      display: flex; align-items: center; gap: 2.5rem;
      background: #EDEDED; border-radius: 12px; padding: 0.65rem 2rem;
    }
    .nav-links-pill a {
      font-size: 13px; font-weight: 500; color: #374151;
      text-decoration: none; transition: color 0.2s;
    }
    .nav-links-pill a:hover { color: #111827; }

    /* HERO */
    .hero-content { flex: 1; display: flex; align-items: flex-end; padding: 0 7rem 5rem 7rem; }
    .hero-inner { max-width: 320px; }

    .badge {
      display: inline-flex; align-items: center; gap: 6px;
      font-size: 11.5px; font-weight: 500; color: #3b82f6;
      text-decoration: none; margin-bottom: 0.75rem;
      transition: color 0.2s;
    }
    .badge:hover { color: #2563eb; }
    .badge .arrow { display: inline-block; transition: transform 0.2s; }
    .badge:hover .arrow { transform: translateX(2px); }

    h1.hero-headline {
      font-size: 1.6rem; line-height: 1.15; font-weight: 500;
      color: #111827; letter-spacing: -0.02em; margin-bottom: 0.75rem;
    }
    p.hero-sub {
      font-size: 13px; color: #9ca3af; font-weight: 400; margin-bottom: 0.75rem; line-height: 1.6;
    }
    .cta-group { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 0.75rem; }
    .cta-primary {
      display: inline-flex; align-items: center; gap: 8px;
      font-size: 13px; font-weight: 500; color: #3b82f6;
      border: 1px solid #93c5fd; border-radius: 9999px; padding: 0.6rem 1.25rem;
      text-decoration: none; transition: all 0.2s; background: transparent;
    }
    .cta-primary:hover { background: #3b82f6; color: #fff; border-color: #3b82f6; }
    .cta-primary:hover .arrow { transform: translateX(2px); }
    .cta-secondary {
      display: inline-flex; align-items: center; gap: 8px;
      font-size: 13px; font-weight: 500; color: #374151;
      border: 1px solid rgba(55,65,81,0.3); border-radius: 9999px; padding: 0.6rem 1.25rem;
      text-decoration: none; transition: all 0.2s; background: rgba(255,255,255,0.6);
    }
    .cta-secondary:hover { background: rgba(255,255,255,0.9); color: #111827; }
    .arrow { display: inline-block; transition: transform 0.2s; }

    @media (max-width: 768px) {
      .hero-content { padding: 0 1.5rem 3rem 1.5rem; }
      h1.hero-headline { font-size: 1.3rem; }
      .nav-links-pill { gap: 1.25rem; padding: 0.55rem 1.2rem; }
    }
  </style>
</head>
<body>
  <video class="video-bg" autoplay="autoplay" muted="muted" loop="loop" playsinline="playsinline">
    <source src="https://d8j0ntlcm91z4.cloudfront.net/user_38xzZboKViGWJOttwIXH07lWA1P/hf_20260508_215831_c6a8989c-d716-4d8d-8745-e972a2eec711.mp4" type="video/mp4"/>
  </video>

  <div class="page-wrapper">
    <nav>
      <div class="nav-logo-pill">
        <svg width="18" height="18" viewBox="0 0 256 256" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path fill="rgb(84,84,84)" d="M 160 88 L 194 34 L 216 0 L 256 0 L 256 40 L 221.5 93.5 L 200 128 L 256 128 L 256 256 L 96 256 L 96 168 L 64.246 220 L 40 256 L 0 256 L 0 216 L 34 162 L 56 128 L 0 128 L 0 0 L 160 0 Z"/>
        </svg>
      </div>
      <div class="nav-links-pill">
        <a href="/apex/Dashboard">Dashboard</a>
        <a href="/apex/Beneficiary">Beneficiaries</a>
        <a href="/apex/History">Transactions</a>
        <a href="/apex/Login">Login</a>
      </div>
    </nav>

    <div class="hero-content">
      <div class="hero-inner">
        <a href="/apex/Register" class="badge">
          <span>Trusted Payment Platform for Global Transactions</span>
          <span class="arrow">→</span>
        </a>
        <h1 class="hero-headline">Secure cross-border payments and transaction tracking built for modern businesses.</h1>
        <p class="hero-sub">Manage payments, beneficiaries, currency conversion, approvals, and transaction monitoring from a single platform.</p>
        <div class="cta-group">
          <a href="/apex/Transfer" class="cta-primary">
            <span>Start a Transfer</span>
            <span class="arrow">→</span>
          </a>
          <a href="/apex/Register" class="cta-secondary">
            <span>Create Account</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
</apex:page>
